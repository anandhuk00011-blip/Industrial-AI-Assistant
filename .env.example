# Neon Postgres production database for auth, tenant isolation, uploads, chats, and audit logs.
# Local development falls back to data/maintenance_copilot.db when DATABASE_URL is omitted.
# Set USE_LOCAL_DATABASE=true only when you want local SQLite even though DATABASE_URL exists.
# DATABASE_URL=postgresql+psycopg://user:password@ep-example.neon.tech/dbname?sslmode=require
USE_LOCAL_DATABASE=false
SQLITE_BUSY_TIMEOUT_SECONDS=60
PASSWORD_HASH_ITERATIONS=260000
API_SECRET_KEY=change-this-long-random-secret-before-production
ACCESS_TOKEN_MAX_AGE_SECONDS=28800
FASTAPI_BASE_URL=http://127.0.0.1:8000
MAX_UPLOAD_FILES=10
MAX_UPLOAD_MB=200
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8501,http://127.0.0.1:8501

# Default tenant for single-org pilot / Streamlit mode
DEFAULT_ORGANIZATION_ID=00000000-0000-4000-8000-000000000001
DEFAULT_ORGANIZATION_NAME=Demo Manufacturing Corp

GEMINI_API_KEY=your_GOOGLE_API_KEY
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.0-flash
GEMINI_MAX_ATTEMPTS=3

FAISS_CANDIDATES=30
HYBRID_CANDIDATES=30
RERANK_TOP_K=8
GENERAL_GUIDANCE_THRESHOLD=-0.25
HASH_EMBEDDING_FEATURES=384
ALLOW_MODEL_DOWNLOADS=false

OCR_MODE=auto
OCR_MIN_TEXT_CHARS=80
OCR_DPI=220
OCR_LANG=eng
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
